# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# LLM API Config (VENICE_API_KEY or GROQ_API_KEY)
# VENICE_API_KEY=your_venice_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Public URL of your local server tunnel (e.g. from localhost.run or ngrok)
TUNNEL_URL=https://your-tunnel-subdomain.lhr.life

# Relayer sponsorship EOA private key (EVM format starting with 0x)
PRIVATE_KEY=0x_your_relayer_private_key_here
